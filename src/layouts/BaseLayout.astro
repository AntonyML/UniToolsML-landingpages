---
import '../styles/global.css';
import PlatformProvider from '@/components/PlatformProvider';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'UniToolsML — La Suite del Estudiante Moderno',
  description = 'Mas de 20 herramientas de procesamiento de PDF, IA generativa y organizacion. Construido con Rust para velocidad extrema, 100% offline.',
} = Astro.props;
const PUBLIC_API_URL = import.meta.env.PUBLIC_API_URL ?? '';
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#09090b" />
    <link rel="icon" href="/icono.ico" />
    <link rel="apple-touch-icon" href="/icono.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline define:vars={{ PUBLIC_API_URL }}>
      window.__PUBLIC_API_URL = PUBLIC_API_URL;
    </script>
  </head>
    <body class="min-h-screen bg-zinc-950 text-zinc-50 overflow-x-hidden">
    <PlatformProvider>
      <slot />
    </PlatformProvider>
  </body>
</html>
