---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/Navbar';
import Newsletter from '@/components/sections/Newsletter';
import FAQ from '@/components/sections/FAQ';
import Footer from '@/components/sections/Footer';
import { Button } from '@/components/ui/button';
import { Download, ShieldCheck, Cpu, Wifi, Monitor } from 'lucide-react';
---

<BaseLayout
  title="UniToolsML para Windows — Descarga directa"
  description="Descarga UniToolsML para Windows. Mas de 40 herramientas offline para estudiantes. Instalador .exe — sin tienda, sin cuenta requerida."
>
  <Navbar client:load />
  <main>

    <!-- Hero de plataforma -->
    <section class="relative isolate min-h-[70vh] flex flex-col items-center justify-center pt-28 pb-16 px-4 overflow-hidden">
      <div class="absolute inset-0 -z-10 bg-radial-glow opacity-70" />
      <div class="absolute inset-0 -z-10 bg-grid-zinc bg-grid opacity-20" />
      <div aria-hidden class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] rounded-full bg-indigo-600/10 blur-[100px] -z-10" />

      <!-- Platform badge -->
      <div class="mb-8 flex items-center gap-2 px-3 py-1.5 rounded-full border border-indigo-500/30 bg-indigo-500/10 text-indigo-300 text-xs font-medium">
        <Monitor class="w-3.5 h-3.5" />
        UniToolsML para Windows
      </div>

      <h1 class="text-center text-4xl sm:text-5xl md:text-6xl font-bold leading-[1.08] tracking-tight max-w-3xl text-gradient mb-4">
        Tu suite completa para el escritorio.
      </h1>
      <p class="text-center text-zinc-400 text-base sm:text-lg max-w-xl leading-relaxed mb-10">
        Instalador .exe, sin tienda, sin cuenta para las herramientas gratuitas. Funciona
        <span class="text-zinc-200 font-medium"> 100% offline</span> en Windows 10 y 11.
      </p>

      <!-- CTA principal -->
      <div class="flex flex-col sm:flex-row items-center gap-3 mb-10">
        <a
          href="#newsletter"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-md bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-500 transition-colors shadow-[0_0_30px_-8px_rgba(99,102,241,0.5)]"
        >
          <Download class="w-4 h-4" />
          Unirme a la lista — Windows
        </a>
        <a href="/" class="text-sm text-zinc-500 hover:text-zinc-300 transition-colors">
          Ver todas las opciones
        </a>
      </div>

      <!-- Feature pills -->
      <div class="flex flex-wrap justify-center gap-2">
        {[
          { icon: ShieldCheck, label: 'Sin cuenta requerida' },
          { icon: Wifi,        label: '100% offline' },
          { icon: Cpu,         label: 'Motor Rust nativo' },
        ].map(({ icon: Icon, label }) => (
          <span class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-zinc-800 bg-zinc-900/50 text-xs text-zinc-400">
            <Icon class="w-3.5 h-3.5 text-zinc-500" />
            {label}
          </span>
        ))}
      </div>
    </section>

    <!-- Pagos info — Windows -->
    <section class="py-16 px-4 border-t border-zinc-800">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500 mb-4">Metodos de pago — Plan Premium</p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <div class="glass-card rounded-xl border border-zinc-800 p-5 flex-1">
            <p class="text-sm font-semibold text-zinc-100 mb-1">SINPE Movil</p>
            <p class="text-xs text-zinc-500">Transferencia instantanea para Costa Rica. Sin comisiones adicionales de nuestra parte.</p>
          </div>
          <div class="glass-card rounded-xl border border-zinc-800 p-5 flex-1">
            <p class="text-sm font-semibold text-zinc-100 mb-1">PayPal</p>
            <p class="text-xs text-zinc-500">Para usuarios internacionales o quienes prefieran pago con tarjeta via PayPal.</p>
          </div>
        </div>
      </div>
    </section>

    <Newsletter client:load />
    <FAQ client:visible />
  </main>
  <Footer client:visible />
</BaseLayout>
