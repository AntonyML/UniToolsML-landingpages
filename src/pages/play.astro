---
// IMPORTANTE: Esta pagina es "Play Store safe".
// No menciona comparaciones de precio con otros canales,
// ni pagos externos (SINPE/PayPal), ni invita a salir de Google Play.
// Cumple con las politicas de distribucion de Google Play.
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/Navbar';
import Newsletter from '@/components/sections/Newsletter';
import FAQ from '@/components/sections/FAQ';
import Footer from '@/components/sections/Footer';
import { ShoppingBag, Star, RefreshCw, ShieldCheck } from 'lucide-react';
---

<BaseLayout
  title="UniToolsML en Google Play Store"
  description="UniToolsML llega a Google Play. Mas de 40 herramientas offline para estudiantes universitarios. Proximamente disponible en Android."
>
  <Navbar client:load />
  <main>

    <section class="relative isolate min-h-[70vh] flex flex-col items-center justify-center pt-28 pb-16 px-4 overflow-hidden">
      <div class="absolute inset-0 -z-10 bg-radial-glow opacity-70" />
      <div class="absolute inset-0 -z-10 bg-grid-zinc bg-grid opacity-20" />
      <!-- Verde Google Play -->
      <div aria-hidden class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] rounded-full bg-emerald-600/8 blur-[100px] -z-10" />

      <div class="mb-8 flex items-center gap-2 px-3 py-1.5 rounded-full border border-emerald-500/30 bg-emerald-500/10 text-emerald-300 text-xs font-medium">
        <ShoppingBag class="w-3.5 h-3.5" />
        UniToolsML — Google Play
      </div>

      <h1 class="text-center text-4xl sm:text-5xl md:text-6xl font-bold leading-[1.08] tracking-tight max-w-3xl text-gradient mb-4">
        Proximamente en Google Play.
      </h1>
      <p class="text-center text-zinc-400 text-base sm:text-lg max-w-xl leading-relaxed mb-10">
        Todas las herramientas de UniToolsML directamente en tu Android.
        Actualizaciones automaticas. Proceso de compra seguro con Google Play Billing.
      </p>

      <div class="flex flex-col sm:flex-row items-center gap-3 mb-10">
        <a
          href="#newsletter"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-md bg-emerald-600 text-white text-sm font-medium hover:bg-emerald-500 transition-colors shadow-[0_0_30px_-8px_rgba(16,185,129,0.4)]"
        >
          <ShoppingBag class="w-4 h-4" />
          Notificarme cuando llegue a Play Store
        </a>
        <a href="/" class="text-sm text-zinc-500 hover:text-zinc-300 transition-colors">
          Ver todas las opciones
        </a>
      </div>

      <!-- Play Store benefits — sin mencion de precios externos -->
      <div class="flex flex-wrap justify-center gap-2">
        {[
          { icon: RefreshCw,   label: 'Actualizaciones automaticas' },
          { icon: Star,        label: 'Resenas y calificaciones' },
          { icon: ShieldCheck, label: 'Distribucion verificada por Google' },
        ].map(({ icon: Icon, label }) => (
          <span class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-zinc-800 bg-zinc-900/50 text-xs text-zinc-400">
            <Icon class="w-3.5 h-3.5 text-zinc-500" />
            {label}
          </span>
        ))}
      </div>
    </section>

    <!-- Que incluira la version Play Store -->
    <section class="py-16 px-4 border-t border-zinc-800">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500 mb-8">Que encontraras en Play Store</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-left">
          {[
            { title: 'Todas las herramientas gratuitas', desc: 'PDF, citas, notas, Pomodoro, flashcards y mas — sin costo adicional.' },
            { title: 'Plan Premium con IA', desc: 'Herramientas de IA generativa disponibles con suscripcion mensual o anual.' },
            { title: 'Funcionamiento offline', desc: 'Las herramientas de documentos y estudio funcionan sin internet.' },
            { title: 'Pago seguro',            desc: 'Todas las compras y suscripciones se procesan a traves de Google Play Billing.' },
          ].map(({ title, desc }) => (
            <div class="glass-card rounded-xl border border-zinc-800 p-5">
              <p class="text-sm font-semibold text-zinc-100 mb-1">{title}</p>
              <p class="text-xs text-zinc-500 leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <Newsletter client:load />
    <FAQ client:visible />
  </main>
  <Footer client:visible />
</BaseLayout>
