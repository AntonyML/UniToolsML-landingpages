---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/sections/Footer";
---

<BaseLayout
    title="Términos y Condiciones de Uso — UniToolsML"
    description="Términos y Condiciones completos y vinculantes de UniToolsML. Software educativo offline para estudiantes universitarios."
