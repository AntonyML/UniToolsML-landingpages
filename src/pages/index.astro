---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/Navbar';
import Hero from '@/components/sections/Hero';
import Features from '@/components/sections/Features';
import TechStack from '@/components/sections/TechStack';
import Newsletter from '@/components/sections/Newsletter';
import FreeValue from '@/components/sections/FreeValue';
import Pricing from '@/components/sections/Pricing';
import FAQ from '@/components/sections/FAQ';
import Footer from '@/components/sections/Footer';
---

<BaseLayout
  title="UniToolsML — Simplifica tus tareas digitales en un solo lugar"
  description="Más de 40 herramientas gratuitas para tareas digitales en un solo espacio. Funciona offline, sin complicaciones y adaptado a tu forma de trabajar."
>
  <Navbar client:load />
  <main>
    <Hero client:load />
    <Features client:visible />
    <FreeValue client:visible />
    <Pricing client:visible />
    <TechStack client:visible />
    <FAQ client:visible />
  </main>
  <Footer client:visible />
</BaseLayout>
